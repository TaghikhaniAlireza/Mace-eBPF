# Local build outputs (make build-agent, pack-deb)
build/

### https://raw.github.com/github/gitignore/master/Rust.gitignore

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Vagrant / kernel matrix (built on host, not committed)
scripts/vm/artifacts/
scripts/vm/matrix-results/

# Go example build artifact (binary named `examples` next to main.go)
clients/go/examples/examples

# These are backup files generated by rustfmt
**/*.rs.bk
# Track generated C header
!include/mace.h
